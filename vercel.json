{
  "functions": {
    "api.py": {
      "runtime": "python@3.9"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api.py" },
    { "source": "/(.*)", "destination": "/frontend/build/$1" }
  ],
  "installCommand": "npm install && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build"
}