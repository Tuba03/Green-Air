{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api.py" },
    { "source": "/(.*)", "destination": "/frontend/build/index.html" }
  ],
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    }
  ]
}